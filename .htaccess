RewriteEngine On

# Опционально: только если сайт всё ещё раздаётся через Apache (XAMPP).
# Полностью без Apache: запускайте FastAPI (run_local_api.ps1) — он отдаёт и HTML, и /api.
# Проксируем запросы mini app к Python API через Apache,
# чтобы можно было использовать один ngrok-туннель на порт 80.
# Пример: /pc_salon/api/products -> http://127.0.0.1:8000/api/products
RewriteRule ^api/(.*)$ http://127.0.0.1:8000/api/$1 [P,L,QSA]

# Для preflight-запросов иногда полезно явно пробросить заголовок Origin
RequestHeader set X-Forwarded-Proto "http"
